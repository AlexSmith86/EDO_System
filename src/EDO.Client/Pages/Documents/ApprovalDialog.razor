@using EDO.Client.Services
@inject ITmcRequestService RequestService
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<MudDialog>
    <DialogContent>
        <MudGrid>
            <MudItem xs="6">
                <MudText Typo="Typo.body2" Color="Color.Secondary">Инициатор</MudText>
                <MudText Typo="Typo.body1">@Request.InitiatorName</MudText>
            </MudItem>
            <MudItem xs="6">
                <MudText Typo="Typo.body2" Color="Color.Secondary">Дата создания</MudText>
                <MudText Typo="Typo.body1">@Request.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</MudText>
            </MudItem>
            <MudItem xs="6">
                <MudText Typo="Typo.body2" Color="Color.Secondary">Проект</MudText>
                <MudText Typo="Typo.body1">@(Request.ProjectName ?? "—")</MudText>
            </MudItem>
            <MudItem xs="6">
                <MudText Typo="Typo.body2" Color="Color.Secondary">Текущий этап</MudText>
                <MudChip T="string" Size="Size.Small" Color="Color.Warning">@(Request.CurrentStageName ?? "На согласовании")</MudChip>
            </MudItem>
        </MudGrid>

        @if (!string.IsNullOrEmpty(Request.CurrentStageDescription))
        {
            <MudAlert Severity="Severity.Info" Class="mt-3" Dense="true" NoIcon="false">
                <MudText Typo="Typo.subtitle2" Style="font-weight: 600;" Class="mb-1">Действия на этапе:</MudText>
                @foreach (var line in Request.CurrentStageDescription.Split('\n'))
                {
                    <MudText Typo="Typo.body2">• @line</MudText>
                }
            </MudAlert>
        }

        <MudText Typo="Typo.subtitle1" Class="mt-4 mb-2" Style="font-weight: 600;">Позиции заявки</MudText>

        <MudTable Items="@Request.Items" Dense="true" Hover="true" Elevation="0" Striped="false">
            <HeaderContent>
                <MudTh>№</MudTh>
                <MudTh>Группа</MudTh>
                <MudTh>Наименование</MudTh>
                <MudTh>Кол-во</MudTh>
                <MudTh>Ед.</MudTh>
                <MudTh>Стоимость</MudTh>
                <MudTh>Срок</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@(Request.Items.IndexOf(context) + 1)</MudTd>
                <MudTd>@(context.GroupName ?? "—")</MudTd>
                <MudTd>@context.Name</MudTd>
                <MudTd>@context.Quantity</MudTd>
                <MudTd>@(context.Unit ?? "—")</MudTd>
                <MudTd>@(context.Price?.ToString("N2") ?? "—")</MudTd>
                <MudTd>@(context.PlannedDeliveryDate?.ToString("dd.MM.yyyy") ?? "—")</MudTd>
            </RowTemplate>
        </MudTable>

        <MudText Typo="Typo.subtitle1" Class="mt-4 mb-2" Style="font-weight: 600;">Изначальные вводные по позициям</MudText>
        @foreach (var item in Request.Items)
        {
            <MudPaper Elevation="0" Outlined="true" Class="pa-3 mb-2">
                <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">@item.Name</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Инициатор позиции: @(item.InitiatorName ?? "—"), @(item.InitiatorPosition ?? "—")
                </MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Ссылка на счёт/КП: @(item.InvoiceLink ?? "—")
                </MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Комментарий инициатора: @(string.IsNullOrWhiteSpace(item.Comment) ? "—" : item.Comment)
                </MudText>
            </MudPaper>
        }

        <MudText Typo="Typo.subtitle1" Class="mt-4 mb-2" Style="font-weight: 600;">Комментарии с прошлых этапов</MudText>
        @if (Request.ApprovalHistory.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Dense="true">
                История согласования пока отсутствует.
            </MudAlert>
        }
        else
        {
            <MudList T="ApprovalHistoryDto" Dense="true" Class="pa-0">
                @foreach (var h in Request.ApprovalHistory)
                {
                    <MudListItem T="ApprovalHistoryDto" Class="pa-0">
                        <MudPaper Elevation="0" Outlined="true" Class="pa-3 mb-2" Style="width: 100%;">
                            <MudText Typo="Typo.body2" Style="font-weight: 600;">
                                <MudChip T="string" Size="Size.Small" Color="@GetDecisionColor(h.Decision)" Class="mr-2">
                                    @h.DecisionDisplay
                                </MudChip>
                                @h.StageName (@h.StagePosition)
                            </MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @h.UserName, @h.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                            </MudText>
                            <MudText Typo="Typo.body2" Class="mt-1">
                                @(string.IsNullOrWhiteSpace(h.Comment) ? "Без комментария" : h.Comment)
                            </MudText>
                        </MudPaper>
                    </MudListItem>
                }
            </MudList>
        }

    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Style="text-transform: none;">Отмена</MudButton>
        <MudSpacer />
        <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="OpenRejectDialog"
                   StartIcon="@Icons.Material.Filled.Close"
                   Style="text-transform: none;">
            Отклонить / На доработку
        </MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="OpenApproveDialog"
                   StartIcon="@Icons.Material.Filled.Check"
                   Style="text-transform: none;">
            Согласовать
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public TmcRequestDto Request { get; set; } = null!;

    private void Cancel() => MudDialog.Cancel();

    private static Color GetDecisionColor(string decision) => decision switch
    {
        "Approved" => Color.Success,
        "Rejected" => Color.Error,
        _ => Color.Info
    };

    private async Task OpenApproveDialog()
    {
        var parameters = new DialogParameters<ApproveRequestDialog>
        {
            { x => x.Request, Request }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ApproveRequestDialog>(
            $"Согласование заявки №{Request.Id}", parameters, options);
        var result = await dialog.Result;

        // Если согласование прошло успешно — закрываем родительский диалог тоже
        if (result is { Canceled: false })
        {
            MudDialog.Close(DialogResult.Ok(true));
        }
    }

    private async Task OpenRejectDialog()
    {
        var parameters = new DialogParameters<RejectRequestDialog>
        {
            { x => x.Request, Request }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<RejectRequestDialog>(
            $"Отклонение заявки №{Request.Id}", parameters, options);
        var result = await dialog.Result;

        // Если отклонение прошло успешно — закрываем родительский диалог тоже
        if (result is { Canceled: false })
        {
            MudDialog.Close(DialogResult.Ok(true));
        }
    }
}
