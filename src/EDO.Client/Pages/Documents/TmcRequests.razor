@page "/documents/tmcrequests"
@attribute [Authorize]
@using EDO.Client.Services
@inject ITmcRequestService RequestService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider
@inject IDialogService DialogService

<MudPaper Elevation="0" Class="pa-4 mb-4 rounded-lg" Style="background: linear-gradient(135deg, #111827 0%, #1E293B 100%); border: 1px solid #1E293B;">
    <MudText Typo="Typo.h5" Style="font-weight: 700;">Электронный реестр — МТО</MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary">
        Мои заявки на товарно-материальные ценности
    </MudText>
</MudPaper>

<MudGrid Class="mb-4">
    <MudItem xs="12" md="4">
        <MudTextField @bind-Value="_searchText" Label="Поиск по наименованию"
                      Variant="Variant.Outlined" Margin="Margin.Dense"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true" />
    </MudItem>
    <MudItem xs="12" md="3">
        <MudSelect T="string" @bind-Value="_statusFilter" Label="Фильтр по статусу"
                   Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
            <MudSelectItem T="string" Value="@("Draft")">Черновик</MudSelectItem>
            <MudSelectItem T="string" Value="@("InApproval")">На согласовании</MudSelectItem>
            <MudSelectItem T="string" Value="@("Rework")">На доработке</MudSelectItem>
            <MudSelectItem T="string" Value="@("Completed")">Выполнено</MudSelectItem>
            <MudSelectItem T="string" Value="@("Approved")">Согласована</MudSelectItem>
            <MudSelectItem T="string" Value="@("Rejected")">Отклонена</MudSelectItem>
        </MudSelect>
    </MudItem>
    <MudItem xs="12" md="5" Class="d-flex align-center">
        <MudButton Variant="Variant.Filled" Color="Color.Warning" StartIcon="@Icons.Material.Filled.Add"
                   OnClick="@(() => Navigation.NavigateTo("/documents/tmcrequests/create"))"
                   Style="text-transform: none;">
            Создать заявку
        </MudButton>
    </MudItem>
</MudGrid>

<MudTable Items="@FilteredItems" Hover="true" Striped="false" Loading="@_loading" Elevation="2"
          Dense="true" Breakpoint="Breakpoint.Sm" T="TmcRequestDto">
    <HeaderContent>
        <MudTh Style="width: 40px;"></MudTh>
        <MudTh>Дата</MudTh>
        <MudTh>Проект</MudTh>
        <MudTh>Инициатор</MudTh>
        <MudTh>Группа ДДС</MudTh>
        <MudTh>Наименование ТМЦ</MudTh>
        <MudTh>Кол-во</MudTh>
        <MudTh>Статус</MudTh>
        <MudTh>Согласование</MudTh>
        <MudTh>Действия</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>
            <MudIconButton Size="Size.Small"
                           Icon="@(IsExpanded(context.Id) ? Icons.Material.Filled.KeyboardArrowUp : Icons.Material.Filled.KeyboardArrowDown)"
                           OnClick="@(() => ToggleExpanded(context.Id))" />
        </MudTd>
        <MudTd DataLabel="Дата">@context.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy")</MudTd>
        <MudTd DataLabel="Проект">@(context.ProjectName ?? "—")</MudTd>
        <MudTd DataLabel="Инициатор">@(context.InitiatorName ?? "Неизвестный")</MudTd>
        <MudTd DataLabel="Группа">
            @if (context.Items?.Any() == true)
            {
                @(context.Items.First().GroupName ?? "—")
                @if (context.Items.Count > 1)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary"> (+@(context.Items.Count - 1))</MudText>
                }
            }
            else
            {
                @:—
            }
        </MudTd>
        <MudTd DataLabel="Наименование">
            @if (context.Items?.Any() == true)
            {
                @(context.Items.First().Name ?? "—")
                @if (context.Items.Count > 1)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary"> (+@(context.Items.Count - 1))</MudText>
                }
            }
            else
            {
                @:—
            }
        </MudTd>
        <MudTd DataLabel="Кол-во">@(context.Items?.Count ?? 0) поз.</MudTd>
        <MudTd DataLabel="Статус">
            <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)">
                @GetStatusText(context.Status)
            </MudChip>
        </MudTd>
        <MudTd DataLabel="Согласование">
            @{
                var progress = GetApprovalProgress(context);
            }
            <MudTooltip Text="@(context.CurrentStageDescription?.Replace("\n", " • ") ?? "")"
                        Placement="Placement.Top" Arrow="true"
                        Style="max-width: 350px;"
                        Disabled="@string.IsNullOrEmpty(context.CurrentStageDescription)">
                <div style="min-width: 130px;">
                    <MudProgressLinear Value="@progress.Percent" Color="@progress.Color"
                                       Size="Size.Small" Rounded="true" Class="mb-1" />
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Align="Align.Center">
                        @progress.Label
                    </MudText>
                    @if (!string.IsNullOrEmpty(context.CurrentStagePosition))
                    {
                        <MudText Typo="Typo.caption" Color="Color.Warning" Align="Align.Center">
                            Ожидает: @context.CurrentStagePosition
                        </MudText>
                    }
                </div>
            </MudTooltip>
        </MudTd>
        <MudTd DataLabel="Действия">
            @{ var isOwner = context.InitiatorUserId == _currentUserId; }
            @if ((context.Status == "Draft" || context.Status == "Rework") && (_isAdmin || isOwner))
            {
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                               OnClick="@(() => Navigation.NavigateTo($"/documents/tmcrequests/edit/{context.Id}"))" />
                <MudIconButton Icon="@Icons.Material.Filled.Send" Size="Size.Small" Color="Color.Success"
                               OnClick="@(() => SendRequest(context.Id))" />
            }
            @if (_isAdmin)
            {
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                               OnClick="@(() => DeleteRequest(context.Id))" />
            }
        </MudTd>
    </RowTemplate>
    <ChildRowContent>
        @if (IsExpanded(context.Id))
        {
            <MudTr>
                <td colspan="10" style="background-color: #1a1a2a; padding: 16px 24px;">
                    <MudText Typo="Typo.subtitle2" Style="font-weight: 600;" Class="mb-2">
                        История согласования заявки №@context.Id
                    </MudText>

                    @if (context.ApprovalHistory.Count == 0)
                    {
                        <MudAlert Severity="Severity.Info" Dense="true">
                            История действий по этой заявке пока отсутствует.
                        </MudAlert>
                    }
                    else
                    {
                        <MudTimeline TimelinePosition="TimelinePosition.Start" TimelineAlign="TimelineAlign.Start">
                            @foreach (var h in context.ApprovalHistory)
                            {
                                <MudTimelineItem Color="@GetDecisionColor(h.Decision)" Size="Size.Small" Elevation="0">
                                    <ItemContent>
                                        <MudPaper Elevation="0" Outlined="true" Class="pa-3">
                                            <div class="d-flex align-center gap-2 mb-1">
                                                <MudChip T="string" Size="Size.Small" Color="@GetDecisionColor(h.Decision)">
                                                    @h.DecisionDisplay
                                                </MudChip>
                                                <MudText Typo="Typo.body2" Style="font-weight: 600;">
                                                    @h.StageName
                                                </MudText>
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                    @h.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                                                </MudText>
                                            </div>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                @(string.IsNullOrWhiteSpace(h.UserPosition) ? h.StagePosition : h.UserPosition), @h.UserName
                                            </MudText>
                                            <MudText Typo="Typo.body2" Class="mt-1">
                                                @(string.IsNullOrWhiteSpace(h.Comment) ? "Без комментария" : h.Comment)
                                            </MudText>
                                        </MudPaper>
                                    </ItemContent>
                                </MudTimelineItem>
                            }
                        </MudTimeline>
                    }
                </td>
            </MudTr>
        }
    </ChildRowContent>
    <NoRecordsContent>
        <MudText>Заявок пока нет</MudText>
    </NoRecordsContent>
    <LoadingContent>
        <MudText>Загрузка...</MudText>
    </LoadingContent>
</MudTable>

@code {
    private List<TmcRequestDto> _items = new();
    private bool _loading = true;
    private string? _searchText;
    private string? _statusFilter;
    private bool _isAdmin;
    private int _currentUserId;
    private readonly HashSet<int> _expanded = new();

    private bool IsExpanded(int id) => _expanded.Contains(id);

    private void ToggleExpanded(int id)
    {
        if (!_expanded.Add(id))
            _expanded.Remove(id);
    }

    private static Color GetDecisionColor(string decision) => decision switch
    {
        "Approved" => Color.Success,
        "Rejected" => Color.Error,
        "Reviewed" => Color.Info,
        _ => Color.Default
    };

    private IEnumerable<TmcRequestDto> FilteredItems
    {
        get
        {
            var result = _items.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(_statusFilter))
                result = result.Where(r => r.Status == _statusFilter);

            if (!string.IsNullOrWhiteSpace(_searchText))
                result = result.Where(r => r.Items?.Any(i =>
                    (i.Name ?? "").Contains(_searchText, StringComparison.OrdinalIgnoreCase)) == true);

            return result;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _isAdmin = authState.User.IsInRole("Администратор");
        var idClaim = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        _ = int.TryParse(idClaim, out _currentUserId);
        await Load();
    }

    private async Task Load()
    {
        _loading = true;
        try { _items = await RequestService.GetMyAsync(); }
        catch (Exception ex) { Snackbar.Add($"Ошибка: {ex.Message}", Severity.Error); }
        finally { _loading = false; }
    }

    private async Task SendRequest(int id)
    {
        var parameters = new DialogParameters<SubmitRequestDialog>
        {
            { x => x.RequestId, id }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<SubmitRequestDialog>(
            $"Отправка заявки №{id} на согласование", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            await Load();
        }
    }

    private async Task DeleteRequest(int id)
    {
        if (!_isAdmin)
        {
            Snackbar.Add("Удаление доступно только администратору", Severity.Warning);
            return;
        }

        try
        {
            await RequestService.DeleteAsync(id);
            Snackbar.Add("Заявка удалена", Severity.Success);
            await Load();
        }
        catch (Exception ex) { Snackbar.Add($"Ошибка: {ex.Message}", Severity.Error); }
    }

    private static Color GetStatusColor(string status) => status switch
    {
        "Draft" => Color.Default,
        "InApproval" => Color.Warning,
        "Rework" => Color.Secondary,
        "Completed" => Color.Success,
        "Approved" => Color.Success,
        "Rejected" => Color.Error,
        _ => Color.Default
    };

    private static string GetStatusText(string status) => status switch
    {
        "Draft" => "Черновик",
        "InApproval" => "На согласовании",
        "Rework" => "На доработке",
        "Completed" => "Выполнено",
        "Approved" => "Согласована",
        "Rejected" => "Отклонена",
        _ => status
    };

    private static (double Percent, Color Color, string Label) GetApprovalProgress(TmcRequestDto request)
    {
        if (request.Status == "Completed" || request.Status == "Approved")
            return (100, Color.Success, "Завершено");

        if (request.Status == "Rejected")
            return (100, Color.Error, "Отклонено");

        if (request.Status == "Draft")
            return (0, Color.Default, "Черновик");

        if (request.TotalStages == 0)
            return (0, Color.Default, "—");

        var pct = (double)request.CurrentStageOrder / request.TotalStages * 100;
        return (pct, Color.Warning, $"{request.CurrentStageOrder} из {request.TotalStages}");
    }
}
