@page "/documents/tmcrequests/create"
@page "/documents/tmcrequests/edit/{Id:int}"
@attribute [Authorize]
@using EDO.Client.Services
@inject ITmcRequestService RequestService
@inject ICategoryService CategoryService
@inject IUserService UserService
@inject IWorkflowChainService ChainService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider
@inject LocalStorageService LocalStorage

<MudPaper Elevation="0" Class="pa-4 mb-4 rounded-lg" Style="background: linear-gradient(135deg, #1e1e2f 0%, #2a2a40 100%); border: 1px solid #333;">
    <MudText Typo="Typo.h5" Style="font-weight: 700;">@(_isEdit ? "Редактирование заявки" : "Новая заявка")</MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary">
        Заполните шапку и табличную часть заявки
    </MudText>
</MudPaper>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Warning" />
}
else
{
    <MudCard Elevation="2" Class="pa-4 mb-4">
        <MudCardContent>
            <MudSelect T="int?" @bind-Value="_selectedChainId"
                       Label="Тип заявки" Variant="Variant.Outlined"
                       Class="mb-4" Dense="true"
                       AdornmentIcon="@Icons.Material.Filled.AccountTree">
                <MudSelectItem T="int?" Value="@((int?)null)">Стандартная заявка на ТМЦ</MudSelectItem>
                @foreach (var chain in _chains)
                {
                    <MudSelectItem T="int?" Value="@((int?)chain.Id)">@chain.Name</MudSelectItem>
                }
            </MudSelect>

            <MudAutocomplete T="string" Value="_projectName"
                             ValueChanged="@OnProjectChanged"
                             TextChanged="@OnProjectTextChanged"
                             Label="Проект" Variant="Variant.Outlined"
                             Class="mb-4"
                             SearchFunc="@SearchProjects"
                             CoerceText="false"
                             CoerceValue="false"
                             Clearable="true"
                             DebounceInterval="300" />

            <MudText Typo="Typo.subtitle1" Class="mb-3" Style="font-weight: 600;">Позиции заявки</MudText>

            @foreach (var item in _items)
            {
                var idx = _items.IndexOf(item);
                <MudCard Elevation="0" Class="pa-3 mb-3" Style="border: 1px solid #333;">
                    <MudGrid>
                        <MudItem xs="12" md="5">
                            <MudSelect T="TmcGroupDto" Value="item.SelectedGroup"
                                       Label="Группа ДДС" Variant="Variant.Outlined"
                                       Dense="true" Margin="Margin.Dense"
                                       ToStringFunc="@(g => g?.DisplayName ?? string.Empty)"
                                       ValueChanged="@(g => OnGroupChanged(item, g))">
                                @foreach (var g in _groups)
                                {
                                    <MudSelectItem T="TmcGroupDto" Value="@g">@g.DisplayName</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="11" md="6">
                            <MudSelect T="TmcSubgroupDto" @bind-Value="item.SelectedSubgroup"
                                       Label="Подгруппа ДДС" Variant="Variant.Outlined"
                                       Dense="true" Margin="Margin.Dense"
                                       Disabled="@(!item.Subgroups.Any(s => !s.IsHeader))"
                                       ToStringFunc="@(s => s?.DisplayName ?? string.Empty)">
                                @foreach (var s in item.Subgroups)
                                {
                                    @if (s.IsHeader)
                                    {
                                        <MudSelectItem T="TmcSubgroupDto" Value="@s" Disabled="true">
                                            <MudText Typo="Typo.caption" Style="font-weight: 700; color: #FFD700; text-transform: uppercase;">
                                                @s.Name
                                            </MudText>
                                        </MudSelectItem>
                                    }
                                    else
                                    {
                                        <MudSelectItem T="TmcSubgroupDto" Value="@s">@s.DisplayName</MudSelectItem>
                                    }
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="1" Class="d-flex align-center justify-center">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                           Color="Color.Error" OnClick="@(() => RemoveItem(item))" />
                        </MudItem>
                        <MudItem xs="12" md="5">
                            <MudAutocomplete T="string" Value="item.InitiatorName"
                                             Label="Инициатор (ФИО)" Variant="Variant.Outlined"
                                             Dense="true" Margin="Margin.Dense"
                                             SearchFunc="@SearchUsers"
                                             CoerceValue="false"
                                             ValueChanged="@(v => OnInitiatorChanged(item, v))" />
                        </MudItem>
                        <MudItem xs="12" md="5">
                            <MudTextField @bind-Value="item.InitiatorPosition" Label="Должность инициатора"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="12" md="5">
                            <MudTextField @bind-Value="item.Name" Label="Наименование ТМЦ"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="4" md="2">
                            <MudNumericField @bind-Value="item.Quantity" Label="Кол-во"
                                             Variant="Variant.Outlined" Min="0.0001m"
                                             Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="4" md="2">
                            <MudAutocomplete T="string" @bind-Value="item.Unit"
                                             Label="Ед. изм." Variant="Variant.Outlined"
                                             Dense="true" Margin="Margin.Dense"
                                             SearchFunc="@SearchUnits"
                                             CoerceText="false"
                                             CoerceValue="false" />
                        </MudItem>
                        <MudItem xs="4" md="2">
                            <MudNumericField @bind-Value="item.Price" Label="Стоимость"
                                             Variant="Variant.Outlined" Min="0m"
                                             Margin="Margin.Dense" Format="N2" />
                        </MudItem>
                        <MudItem xs="4" md="3">
                            <MudDatePicker @bind-Date="item.PlannedDeliveryDate" Label="Срок поставки"
                                           Color="Color.Warning"
                                           ShowToolbar="false"
                                           Variant="Variant.Outlined" Margin="Margin.Dense"
                                           DateFormat="dd.MM.yyyy" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="item.InvoiceLink" Label="Ссылка на счёт/КП"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="item.Comment" Label="Комментарий"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                    </MudGrid>
                </MudCard>
            }

            <MudButton Variant="Variant.Outlined" Color="Color.Warning"
                       StartIcon="@Icons.Material.Filled.AddCircleOutline"
                       OnClick="@AddItem" Class="mt-2" Style="text-transform: none;">
                Добавить строку
            </MudButton>
        </MudCardContent>

        <MudCardActions Class="pa-4 pt-0">
            <MudButton Variant="Variant.Text" OnClick="@GoBack" Style="text-transform: none;">
                Отмена
            </MudButton>
            <MudSpacer />
            <MudButton Variant="Variant.Filled" Color="Color.Warning"
                       OnClick="@Save" Disabled="@_saving"
                       Style="text-transform: none;">
                @if (_saving)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                @(_isEdit ? "Сохранить" : "Создать черновик")
            </MudButton>
        </MudCardActions>
    </MudCard>
}

@code {
    [Parameter] public int? Id { get; set; }

    private List<RequestItemRow> _items = new();
    private List<TmcGroupDto> _groups = new();
    private List<UserDto> _users = new();
    private List<WorkflowChainDto> _chains = new();
    private int? _selectedChainId;
    private string? _projectName;
    private bool _loading = true;
    private bool _saving;
    private bool _isEdit;
    private bool _isAdmin;
    private List<string> _projectSuggestions = new();

    private const string ProjectSuggestionsKey = "tmc_request_project_suggestions_v1";
    private const int MaxProjectSuggestions = 30;

    private static readonly string[] _unitOptions = {
        "шт.", "м3", "м2", "м.п.", "т.", "кг.", "уп.", "бал.", "рул.", "компл.", "ч/час.", "маш-см.", "усл. ед."
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            _isAdmin = authState.User.IsInRole("Администратор");

            _groups = await CategoryService.GetGroupsAsync();
            _users = await UserService.GetAllAsync();
            _chains = await ChainService.GetActiveAsync();
            await LoadProjectSuggestionsAsync();

            if (Id.HasValue)
            {
                if (!_isAdmin)
                {
                    Snackbar.Add("Редактирование вводных доступно только администратору", Severity.Warning);
                    Navigation.NavigateTo("/documents/tmcrequests");
                    return;
                }
                _isEdit = true;
                var existing = await RequestService.GetByIdAsync(Id.Value);
                if (existing is not null)
                {
                    _projectName = existing.ProjectName;
                    foreach (var i in existing.Items)
                    {
                        var row = new RequestItemRow
                        {
                            Name = i.Name,
                            Quantity = i.Quantity,
                            Unit = i.Unit,
                            Price = i.Price,
                            PlannedDeliveryDate = i.PlannedDeliveryDate,
                            InvoiceLink = i.InvoiceLink,
                            Comment = i.Comment,
                            InitiatorName = i.InitiatorName,
                            InitiatorPosition = i.InitiatorPosition
                        };

                        if (i.GroupId.HasValue)
                        {
                            row.SelectedGroup = _groups.FirstOrDefault(g => g.Id == i.GroupId.Value);
                            if (row.SelectedGroup != null)
                            {
                                row.Subgroups = await CategoryService.GetSubgroupsAsync(row.SelectedGroup.Id);
                                AppendOtherOption(row.Subgroups);
                                if (i.SubgroupId.HasValue)
                                    row.SelectedSubgroup = row.Subgroups.FirstOrDefault(s => s.Id == i.SubgroupId.Value);
                            }
                        }

                        _items.Add(row);
                    }
                }
            }
        }
        catch (Exception ex) { Snackbar.Add($"Ошибка: {ex.Message}", Severity.Error); }
        finally { _loading = false; }
    }

    private void AddItem()
    {
        _items.Add(new RequestItemRow());
    }

    private void RemoveItem(RequestItemRow item)
    {
        _items.Remove(item);
    }

    private async Task OnGroupChanged(RequestItemRow item, TmcGroupDto? group)
    {
        item.SelectedGroup = group;
        item.SelectedSubgroup = null;
        item.Subgroups = group != null
            ? await CategoryService.GetSubgroupsAsync(group.Id)
            : new();
        AppendOtherOption(item.Subgroups);
    }

    private static void AppendOtherOption(List<TmcSubgroupDto> subgroups)
    {
        if (subgroups.Count == 0) return;
        subgroups.Add(new TmcSubgroupDto
        {
            Id = 0,
            Name = "Иное",
            IsOther = true
        });
    }

    private async Task Save()
    {
        if (_items.Count == 0)
        {
            Snackbar.Add("Добавьте хотя бы одну позицию", Severity.Warning);
            return;
        }

        if (_items.Any(i => string.IsNullOrWhiteSpace(i.Name)))
        {
            Snackbar.Add("Заполните наименование для всех позиций", Severity.Warning);
            return;
        }

        if (_items.Any(i => i.Quantity <= 0))
        {
            Snackbar.Add("Количество должно быть больше 0", Severity.Warning);
            return;
        }

        _saving = true;
        try
        {
            var dtoItems = _items.Select(i => new CreateTmcRequestItemDto
            {
                GroupId = i.SelectedGroup?.Id,
                SubgroupId = i.SelectedSubgroup is { IsOther: false } ? i.SelectedSubgroup.Id : null,
                Name = i.Name,
                Quantity = i.Quantity,
                Unit = i.Unit,
                Price = i.Price,
                PlannedDeliveryDate = i.PlannedDeliveryDate,
                InvoiceLink = i.InvoiceLink,
                Comment = i.Comment,
                InitiatorName = i.InitiatorName,
                InitiatorPosition = i.InitiatorPosition
            }).ToList();

            if (_isEdit && Id.HasValue)
            {
                await RequestService.UpdateAsync(Id.Value, new UpdateTmcRequestDto
                {
                    ProjectName = _projectName,
                    Items = dtoItems
                });
                Snackbar.Add("Заявка обновлена", Severity.Success);
            }
            else
            {
                await RequestService.CreateAsync(new CreateTmcRequestDto
                {
                    ProjectName = _projectName,
                    WorkflowChainId = _selectedChainId,
                    Items = dtoItems
                });
                Snackbar.Add("Заявка создана", Severity.Success);
            }

            await SaveProjectSuggestionAsync(_projectName);

            Navigation.NavigateTo("/documents/tmcrequests");
        }
        catch (Exception ex) { Snackbar.Add($"Ошибка: {ex.Message}", Severity.Error); }
        finally { _saving = false; }
    }

    private void OnProjectChanged(string? value) => _projectName = value;
    private void OnProjectTextChanged(string? text) => _projectName = text;

    private void GoBack() => Navigation.NavigateTo("/documents/tmcrequests");

    private Task<IEnumerable<string>> SearchUsers(string value, CancellationToken token)
    {
        var result = string.IsNullOrEmpty(value)
            ? _users.Select(u => $"{u.LastName} {u.FirstName} {u.MiddleName}".Trim())
            : _users
                .Select(u => $"{u.LastName} {u.FirstName} {u.MiddleName}".Trim())
                .Where(n => n.Contains(value, StringComparison.OrdinalIgnoreCase));
        return Task.FromResult(result);
    }

    private Task<IEnumerable<string>> SearchProjects(string value, CancellationToken token)
    {
        IEnumerable<string> result = _projectSuggestions;
        if (!string.IsNullOrWhiteSpace(value))
        {
            result = result.Where(p => p.Contains(value, StringComparison.OrdinalIgnoreCase));
        }
        return Task.FromResult(result);
    }

    private void OnInitiatorChanged(RequestItemRow item, string? value)
    {
        item.InitiatorName = value;
        var user = _users.FirstOrDefault(u =>
            $"{u.LastName} {u.FirstName} {u.MiddleName}".Trim() == value);
        if (user != null)
            item.InitiatorPosition = user.Position;
    }

    private Task<IEnumerable<string>> SearchUnits(string value, CancellationToken token)
    {
        var result = string.IsNullOrEmpty(value)
            ? _unitOptions.AsEnumerable()
            : _unitOptions.Where(u => u.Contains(value, StringComparison.OrdinalIgnoreCase));
        return Task.FromResult(result);
    }

    private async Task LoadProjectSuggestionsAsync()
    {
        try
        {
            var raw = await LocalStorage.GetItemAsync(ProjectSuggestionsKey);
            if (string.IsNullOrWhiteSpace(raw))
            {
                _projectSuggestions = new();
                return;
            }

            _projectSuggestions = System.Text.Json.JsonSerializer.Deserialize<List<string>>(raw) ?? new();
        }
        catch
        {
            _projectSuggestions = new();
        }
    }

    private async Task SaveProjectSuggestionAsync(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return;

        var normalized = value.Trim();
        _projectSuggestions.RemoveAll(p => string.Equals(p, normalized, StringComparison.OrdinalIgnoreCase));
        _projectSuggestions.Insert(0, normalized);

        if (_projectSuggestions.Count > MaxProjectSuggestions)
            _projectSuggestions = _projectSuggestions.Take(MaxProjectSuggestions).ToList();

        var serialized = System.Text.Json.JsonSerializer.Serialize(_projectSuggestions);
        await LocalStorage.SetItemAsync(ProjectSuggestionsKey, serialized);
    }

    private class RequestItemRow
    {
        public TmcGroupDto? SelectedGroup { get; set; }
        public TmcSubgroupDto? SelectedSubgroup { get; set; }
        public List<TmcSubgroupDto> Subgroups { get; set; } = new();
        public string Name { get; set; } = string.Empty;
        public decimal Quantity { get; set; } = 1;
        public string? Unit { get; set; }
        public decimal? Price { get; set; }
        public DateTime? PlannedDeliveryDate { get; set; }
        public string? InvoiceLink { get; set; }
        public string? Comment { get; set; }
        public string? InitiatorName { get; set; }
        public string? InitiatorPosition { get; set; }
    }
}
