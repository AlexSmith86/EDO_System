@using EDO.Client.Services
@using Microsoft.AspNetCore.Components.Forms
@inject ITmcRequestService RequestService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
            Выберите, на какой из следующих этапов передать заявку. По умолчанию —
            ближайший следующий этап. Вы можете пропустить промежуточные этапы,
            если это оправдано.
        </MudText>

        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="my-3" />
        }
        else if (_targets.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">
                Это финальный этап маршрута — после согласования заявка будет закрыта.
            </MudAlert>
        }
        else
        {
            <MudSelect T="ForwardTargetKey"
                       Value="_selectedKey"
                       ValueChanged="@OnTargetChanged"
                       Label="Передать на этап"
                       Variant="Variant.Outlined"
                       Required="true"
                       RequiredError="Выберите следующий этап"
                       AnchorOrigin="Origin.BottomCenter"
                       Class="mb-3">
                @foreach (var t in _targets)
                {
                    <MudSelectItem T="ForwardTargetKey" Value="@KeyOf(t)">
                        @BuildLabel(t)
                    </MudSelectItem>
                }
            </MudSelect>

            @if (_selectedTarget is not null && !string.IsNullOrWhiteSpace(_selectedTarget.Description))
            {
                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">
                    <MudText Typo="Typo.subtitle2" Style="font-weight: 600;" Class="mb-1">
                        Действия на выбранном этапе:
                    </MudText>
                    @foreach (var line in _selectedTarget.Description.Split('\n'))
                    {
                        <MudText Typo="Typo.body2">• @line</MudText>
                    }
                </MudAlert>
            }

            @if (IsSkipping())
            {
                <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-2">
                    Вы пропускаете промежуточные этапы. Это действие будет зафиксировано в истории заявки.
                </MudAlert>
            }
        }

        <MudTextField @bind-Value="_comment"
                      Label="Комментарий (необязательно)"
                      Variant="Variant.Outlined"
                      Lines="3"
                      Class="mt-2" />

        <MudText Typo="Typo.subtitle2" Class="mt-4 mb-1" Style="font-weight: 600;">
            Прикрепить файл (необязательно)
        </MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2 d-block">
            Любой тип, до 50 МБ. Файл попадёт в историю заявки и будет доступен для скачивания.
        </MudText>

        <MudFileUpload T="IBrowserFile"
                       FilesChanged="OnFileSelected"
                       MaximumFileCount="1"
                       Accept="*/*">
            <CustomContent Context="fileUpload">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.AttachFile"
                           OnClick="@(async () => await fileUpload.OpenFilePickerAsync())"
                           Style="text-transform: none;">
                    @(_selectedFile is null ? "Выбрать файл" : "Заменить файл")
                </MudButton>
            </CustomContent>
        </MudFileUpload>

        @if (_selectedFile is not null)
        {
            <MudChip T="string"
                     Size="Size.Small"
                     Color="Color.Primary"
                     Icon="@Icons.Material.Filled.Description"
                     OnClose="ClearFile"
                     Class="mt-2">
                @_selectedFile.Name (@FormatSize(_selectedFile.Size))
            </MudChip>
            @if (!string.IsNullOrEmpty(_fileError))
            {
                <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2">@_fileError</MudAlert>
            }
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Style="text-transform: none;">Отмена</MudButton>
        <MudSpacer />
        <MudButton Variant="Variant.Filled"
                   Color="Color.Success"
                   OnClick="Submit"
                   Disabled="@(_processing || _loading)"
                   StartIcon="@Icons.Material.Filled.Check"
                   Style="text-transform: none;">
            @(_targets.Count == 0 ? "Завершить согласование" : "Согласовать")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public TmcRequestDto Request { get; set; } = null!;

    private const long MaxFileSizeBytes = 50L * 1024 * 1024;

    private List<ForwardTargetDto> _targets = new();
    private ForwardTargetKey _selectedKey;
    private ForwardTargetDto? _selectedTarget;
    private string? _comment;
    private bool _loading = true;
    private bool _processing;

    private IBrowserFile? _selectedFile;
    private string? _fileError;

    public readonly record struct ForwardTargetKey(int? StageId, int? WorkflowStepId);

    private static ForwardTargetKey KeyOf(ForwardTargetDto t) => new(t.StageId, t.WorkflowStepId);

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        try
        {
            _targets = await RequestService.GetForwardTargetsAsync(Request.Id);

            var defaultItem = _targets.FirstOrDefault(t => t.IsDefault) ?? _targets.FirstOrDefault();
            if (defaultItem is not null)
            {
                _selectedKey = KeyOf(defaultItem);
                _selectedTarget = defaultItem;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Не удалось загрузить следующие этапы: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void OnTargetChanged(ForwardTargetKey key)
    {
        _selectedKey = key;
        _selectedTarget = _targets.FirstOrDefault(t => KeyOf(t).Equals(key));
    }

    /// <summary>Возвращает true, если выбранный этап НЕ является ближайшим следующим.</summary>
    private bool IsSkipping()
    {
        if (_selectedTarget is null || _targets.Count == 0) return false;
        var first = _targets[0];
        return !KeyOf(first).Equals(KeyOf(_selectedTarget));
    }

    private static string BuildLabel(ForwardTargetDto t) =>
        $"{t.Order}. {t.Name} ({t.Position})";

    private void Cancel() => MudDialog.Cancel();

    private void OnFileSelected(IBrowserFile? file)
    {
        _fileError = null;
        if (file is null)
        {
            _selectedFile = null;
            return;
        }

        if (file.Size > MaxFileSizeBytes)
        {
            _fileError = $"Файл слишком большой: {file.Size / (1024 * 1024)} МБ. Максимум — 50 МБ.";
            _selectedFile = null;
            return;
        }

        _selectedFile = file;
    }

    private void ClearFile(MudBlazor.MudChip<string> _)
    {
        _selectedFile = null;
        _fileError = null;
    }

    private static string FormatSize(long bytes) =>
        bytes >= 1024 * 1024
            ? $"{bytes / 1024.0 / 1024.0:0.#} МБ"
            : $"{Math.Max(1, bytes / 1024)} КБ";

    private async Task Submit()
    {
        if (_selectedFile is not null && !string.IsNullOrEmpty(_fileError))
        {
            Snackbar.Add(_fileError, Severity.Error);
            return;
        }

        _processing = true;
        try
        {
            // Шаг 1: если пользователь приложил файл — сначала заливаем его,
            // получаем URL, и уже его кладём в SubmitDecisionDto. Это позволяет
            // оставить /decision чисто JSON-овым и не биться с multipart в WASM.
            string? attachedName = null;
            string? attachedUrl = null;

            if (_selectedFile is not null)
            {
                // 50 МБ максимум — OpenReadStream требует явного лимита,
                // иначе бросит исключение для файлов > 500 КБ (дефолт SignalR).
                await using var stream = _selectedFile.OpenReadStream(MaxFileSizeBytes);
                var uploaded = await RequestService.UploadAttachmentAsync(
                    Request.Id,
                    stream,
                    _selectedFile.Name,
                    _selectedFile.ContentType);

                if (uploaded is null)
                    throw new InvalidOperationException("Сервер не вернул метаданные файла.");

                attachedName = uploaded.FileName;
                attachedUrl = uploaded.Url;
            }

            // Шаг 2: отправляем решение с ссылкой на уже загруженный файл.
            // Если список пуст (финальный этап) — передаём решение без target (завершение).
            var dto = new SubmitDecisionDto
            {
                Decision = "Approved",
                Comment = _comment,
                TargetStageId = _selectedTarget?.StageId,
                TargetWorkflowStepId = _selectedTarget?.WorkflowStepId,
                AttachedFileName = attachedName,
                AttachedFileUrl = attachedUrl
            };

            await RequestService.SubmitDecisionAsync(Request.Id, dto);

            string msg;
            if (_targets.Count == 0)
                msg = "Заявка полностью согласована";
            else if (IsSkipping())
                msg = $"Заявка передана на этап «{_selectedTarget!.Name}» с пропуском промежуточных";
            else
                msg = $"Заявка передана на этап «{_selectedTarget!.Name}»";

            Snackbar.Add(msg, Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Ошибка: {ex.Message}", Severity.Error);
        }
        finally
        {
            _processing = false;
        }
    }
}
