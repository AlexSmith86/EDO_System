@page "/login"
@layout MinimalLayout
@using EDO.Client.Services
@inject HttpClient Http
@inject JwtAuthenticationStateProvider AuthProvider
@inject NavigationManager Navigation

<MudContainer MaxWidth="MaxWidth.ExtraSmall" Class="d-flex align-center" Style="min-height: 100vh;">
    <MudCard Elevation="4" Class="pa-6 rounded-lg" Style="width: 100%;">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h5" Align="Align.Center" Class="mb-2"
                         Style="font-weight: 600;">
                    @(_step == 1 ? "Вход в систему" : "Подтверждение")
                </MudText>
                <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary">
                    @(_step == 1 ? "Электронный документооборот" : "Введите код из Telegram-бота")
                </MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true">@_errorMessage</MudAlert>
            }

            @if (!string.IsNullOrEmpty(_infoMessage))
            {
                <MudAlert Severity="Severity.Info" Class="mb-4" Dense="true">@_infoMessage</MudAlert>
            }

            @if (_step == 1)
            {
                <MudTextField @bind-Value="_email" Label="Email" Variant="Variant.Outlined"
                              InputType="InputType.Email" Class="mb-4"
                              Immediate="true" />
                <MudTextField @bind-Value="_password" Label="Пароль" Variant="Variant.Outlined"
                              InputType="InputType.Password" Class="mb-4"
                              Immediate="true"
                              OnKeyDown="@OnLoginKeyDown" />
                <MudButton Variant="Variant.Filled" Color="Color.Warning" FullWidth="true"
                           Size="Size.Large" OnClick="@HandleLogin" Disabled="@_loading"
                           Class="mt-2" Style="text-transform: none; font-weight: 600;">
                    @if (_loading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    Войти
                </MudButton>
            }
            else
            {
                <MudTextField @bind-Value="_code" Label="6-значный код" Variant="Variant.Outlined"
                              InputType="InputType.Text" Class="mb-4"
                              MaxLength="6" Immediate="true"
                              OnKeyDown="@OnVerifyKeyDown" />
                <MudButton Variant="Variant.Filled" Color="Color.Warning" FullWidth="true"
                           Size="Size.Large" OnClick="@HandleVerify2Fa" Disabled="@_loading"
                           Class="mt-2" Style="text-transform: none; font-weight: 600;">
                    @if (_loading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    Подтвердить
                </MudButton>
                <MudButton Variant="Variant.Text" Color="Color.Secondary" FullWidth="true"
                           Size="Size.Small" OnClick="@BackToLogin" Class="mt-2"
                           Style="text-transform: none;">
                    Назад
                </MudButton>
            }
        </MudCardContent>
    </MudCard>
</MudContainer>

@code {
    private int _step = 1;
    private string _email = string.Empty;
    private string _password = string.Empty;
    private string _code = string.Empty;
    private string? _errorMessage;
    private string? _infoMessage;
    private bool _loading;

    private async Task OnLoginKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await HandleLogin();
    }

    private async Task OnVerifyKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await HandleVerify2Fa();
    }

    private async Task HandleLogin()
    {
        _errorMessage = null;
        _loading = true;

        try
        {
            var response = await Http.PostAsJsonAsync("api/auth/login",
                new { Email = _email, Password = _password });

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ServerMessage>();
                _infoMessage = result?.Message;
                _step = 2;
            }
            else
            {
                var error = await response.Content.ReadFromJsonAsync<ErrorResponse>();
                _errorMessage = error?.Message ?? "Ошибка авторизации.";
            }
        }
        catch
        {
            _errorMessage = "Не удалось подключиться к серверу.";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task HandleVerify2Fa()
    {
        _errorMessage = null;
        _loading = true;

        try
        {
            var response = await Http.PostAsJsonAsync("api/auth/verify-2fa",
                new { Email = _email, Code = _code });

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<TokenResponse>();
                if (result?.Token is not null)
                {
                    await AuthProvider.MarkUserAsAuthenticated(result.Token);
                    Navigation.NavigateTo("/", forceLoad: false);
                }
            }
            else
            {
                var error = await response.Content.ReadFromJsonAsync<ErrorResponse>();
                _errorMessage = error?.Message ?? "Неверный код.";
            }
        }
        catch
        {
            _errorMessage = "Не удалось подключиться к серверу.";
        }
        finally
        {
            _loading = false;
        }
    }

    private void BackToLogin()
    {
        _step = 1;
        _code = string.Empty;
        _errorMessage = null;
        _infoMessage = null;
    }

    private record ErrorResponse(string? Message);
    private record ServerMessage(string? Message);
    private record TokenResponse(string? Token);
}
