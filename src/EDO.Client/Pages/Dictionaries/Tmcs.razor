@page "/dictionaries/tmcs"
@attribute [Authorize]
@using EDO.Client.Services
@inject ITmcService TmcService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudPaper Elevation="0" Class="pa-4 mb-4 rounded-lg" Style="background: linear-gradient(135deg, #1e1e2f 0%, #2a2a40 100%); border: 1px solid #333;">
    <MudText Typo="Typo.h5" Style="font-weight: 700;">ТМЦ — Товарно-материальные ценности</MudText>
</MudPaper>

<MudButton Variant="Variant.Filled" Color="Color.Warning" StartIcon="@Icons.Material.Filled.Add"
           OnClick="@OpenCreateDialog" Class="mb-4" Style="text-transform: none;">
    Добавить ТМЦ
</MudButton>

<MudTable Items="@_items" Hover="true" Striped="true" Loading="@_loading" Elevation="2"
          Dense="true" Breakpoint="Breakpoint.Sm">
    <HeaderContent>
        <MudTh>Наименование</MudTh>
        <MudTh>Артикул</MudTh>
        <MudTh>Остаток</MudTh>
        <MudTh>Внешний ID</MudTh>
        <MudTh>Действия</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Наименование">@context.Name</MudTd>
        <MudTd DataLabel="Артикул">@(context.Article ?? "—")</MudTd>
        <MudTd DataLabel="Остаток">@context.StockBalance</MudTd>
        <MudTd DataLabel="Внешний ID">@(context.ExternalId ?? "—")</MudTd>
        <MudTd DataLabel="Действия">
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                           OnClick="@(() => OpenEditDialog(context))" />
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText>Записи не найдены</MudText>
    </NoRecordsContent>
    <LoadingContent>
        <MudText>Загрузка...</MudText>
    </LoadingContent>
</MudTable>

@code {
    private List<TmcDto> _items = new();
    private bool _loading = true;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        _loading = true;
        try { _items = await TmcService.GetAllAsync(); }
        catch (Exception ex) { Snackbar.Add($"Ошибка: {ex.Message}", Severity.Error); }
        finally { _loading = false; }
    }

    private async Task OpenCreateDialog()
    {
        var parameters = new DialogParameters<TmcDialog>
        {
            { x => x.Model, new TmcDialog.TmcDialogModel() },
            { x => x.IsEdit, false }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<TmcDialog>("Новая ТМЦ", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: TmcDialog.TmcDialogModel model })
        {
            try
            {
                await TmcService.CreateAsync(new CreateTmcDto
                {
                    Name = model.Name, Article = model.Article,
                    ExternalId = model.ExternalId, StockBalance = model.StockBalance
                });
                Snackbar.Add("ТМЦ создана", Severity.Success);
                await Load();
            }
            catch (Exception ex) { Snackbar.Add($"Ошибка: {ex.Message}", Severity.Error); }
        }
    }

    private async Task OpenEditDialog(TmcDto item)
    {
        var model = new TmcDialog.TmcDialogModel
        {
            Name = item.Name, Article = item.Article,
            ExternalId = item.ExternalId, StockBalance = item.StockBalance
        };
        var parameters = new DialogParameters<TmcDialog>
        {
            { x => x.Model, model },
            { x => x.IsEdit, true }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<TmcDialog>("Редактирование", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: TmcDialog.TmcDialogModel edited })
        {
            try
            {
                await TmcService.UpdateAsync(item.Id, new UpdateTmcDto
                {
                    Name = edited.Name, Article = edited.Article,
                    ExternalId = edited.ExternalId, StockBalance = edited.StockBalance
                });
                Snackbar.Add("ТМЦ обновлена", Severity.Success);
                await Load();
            }
            catch (Exception ex) { Snackbar.Add($"Ошибка: {ex.Message}", Severity.Error); }
        }
    }
}
