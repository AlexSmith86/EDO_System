@page "/dictionaries/templates"
@attribute [Authorize]
@using EDO.Client.Services
@inject ITemplateService TemplateService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<MudPaper Elevation="0" Class="pa-4 mb-4 rounded-lg" Style="background: linear-gradient(135deg, #2B2510 0%, #3D3418 100%); border: 1px solid #5A4A12;">
    <MudText Typo="Typo.h5" Style="font-weight: 700;">Шаблоны документов</MudText>
</MudPaper>

<MudButton Variant="Variant.Filled" Color="Color.Warning" StartIcon="@Icons.Material.Filled.Add"
           OnClick="@OpenCreateDialog" Class="mb-4" Style="text-transform: none;">
    Добавить шаблон
</MudButton>

<MudTable Items="@_items" Hover="true" Striped="false" Loading="@_loading" Elevation="2"
          Dense="true" Breakpoint="Breakpoint.Sm">
    <HeaderContent>
        <MudTh>Название</MudTh>
        <MudTh>Путь к файлу</MudTh>
        <MudTh>Тип процесса</MudTh>
        <MudTh>Действия</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Название">@context.Name</MudTd>
        <MudTd DataLabel="Путь к файлу">@context.FilePath</MudTd>
        <MudTd DataLabel="Тип процесса">
            <MudChip T="string" Size="Size.Small" Color="Color.Primary">@context.ProcessType</MudChip>
        </MudTd>
        <MudTd DataLabel="Действия">
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                           OnClick="@(() => OpenEditDialog(context))" />
            @if (_isAdmin)
            {
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                               OnClick="@(() => DeleteItem(context.Id))" />
            }
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText>Записи не найдены</MudText>
    </NoRecordsContent>
    <LoadingContent>
        <MudText>Загрузка...</MudText>
    </LoadingContent>
</MudTable>

@code {
    private List<TemplateDto> _items = new();
    private bool _loading = true;
    private bool _isAdmin;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _isAdmin = authState.User.IsInRole("Администратор");
        await Load();
    }

    private async Task Load()
    {
        _loading = true;
        try { _items = await TemplateService.GetAllAsync(); }
        catch (Exception ex) { Snackbar.Add($"Ошибка: {ex.Message}", Severity.Error); }
        finally { _loading = false; }
    }

    private async Task OpenCreateDialog()
    {
        var parameters = new DialogParameters<TemplateDialog>
        {
            { x => x.Model, new TemplateDialog.TemplateDialogModel() },
            { x => x.IsEdit, false }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<TemplateDialog>("Новый шаблон", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: TemplateDialog.TemplateDialogModel model })
        {
            try
            {
                await TemplateService.CreateAsync(new CreateTemplateDto
                {
                    Name = model.Name, FilePath = model.FilePath, ProcessType = model.ProcessType
                });
                Snackbar.Add("Шаблон создан", Severity.Success);
                await Load();
            }
            catch (Exception ex) { Snackbar.Add($"Ошибка: {ex.Message}", Severity.Error); }
        }
    }

    private async Task OpenEditDialog(TemplateDto item)
    {
        var model = new TemplateDialog.TemplateDialogModel
        {
            Name = item.Name, FilePath = item.FilePath, ProcessType = item.ProcessType
        };
        var parameters = new DialogParameters<TemplateDialog>
        {
            { x => x.Model, model },
            { x => x.IsEdit, true }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<TemplateDialog>("Редактирование", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: TemplateDialog.TemplateDialogModel edited })
        {
            try
            {
                await TemplateService.UpdateAsync(item.Id, new UpdateTemplateDto
                {
                    Name = edited.Name, FilePath = edited.FilePath, ProcessType = edited.ProcessType
                });
                Snackbar.Add("Шаблон обновлён", Severity.Success);
                await Load();
            }
            catch (Exception ex) { Snackbar.Add($"Ошибка: {ex.Message}", Severity.Error); }
        }
    }

    private async Task DeleteItem(int id)
    {
        if (!_isAdmin)
        {
            Snackbar.Add("Удаление доступно только администратору", Severity.Warning);
            return;
        }

        try
        {
            await TemplateService.DeleteAsync(id);
            Snackbar.Add("Шаблон удалён", Severity.Success);
            await Load();
        }
        catch (Exception ex) { Snackbar.Add($"Ошибка: {ex.Message}", Severity.Error); }
    }
}
