@page "/dictionaries/contractors"
@attribute [Authorize]
@using EDO.Client.Services
@inject IContractorService ContractorService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<MudPaper Elevation="0" Class="pa-4 mb-4 rounded-lg" Style="background: linear-gradient(135deg, #2B2510 0%, #3D3418 100%); border: 1px solid #5A4A12;">
    <MudText Typo="Typo.h5" Style="font-weight: 700;">Контрагенты</MudText>
</MudPaper>

<MudButton Variant="Variant.Filled" Color="Color.Warning" StartIcon="@Icons.Material.Filled.Add"
           OnClick="@OpenCreateDialog" Class="mb-4" Style="text-transform: none;">
    Добавить контрагента
</MudButton>

<MudTable Items="@_items" Hover="true" Striped="false" Loading="@_loading" Elevation="2"
          Dense="true" Breakpoint="Breakpoint.Sm">
    <HeaderContent>
        <MudTh>Наименование</MudTh>
        <MudTh>ИНН</MudTh>
        <MudTh>Тип</MudTh>
        <MudTh>Внешний ID</MudTh>
        <MudTh>Действия</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Наименование">@context.Name</MudTd>
        <MudTd DataLabel="ИНН">@(context.Inn ?? "—")</MudTd>
        <MudTd DataLabel="Тип">
            <MudChip T="string" Size="Size.Small"
                     Color="@(context.ContractorType == "Supplier" ? Color.Info : Color.Success)">
                @(context.ContractorType == "Supplier" ? "Поставщик" : "Клиент")
            </MudChip>
        </MudTd>
        <MudTd DataLabel="Внешний ID">@(context.ExternalId ?? "—")</MudTd>
        <MudTd DataLabel="Действия">
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                           OnClick="@(() => OpenEditDialog(context))" />
            @if (_isAdmin)
            {
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                               OnClick="@(() => DeleteItem(context.Id))" />
            }
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText>Записи не найдены</MudText>
    </NoRecordsContent>
    <LoadingContent>
        <MudText>Загрузка...</MudText>
    </LoadingContent>
</MudTable>

@code {
    private List<ContractorDto> _items = new();
    private bool _loading = true;
    private bool _isAdmin;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _isAdmin = authState.User.IsInRole("Администратор");
        await Load();
    }

    private async Task Load()
    {
        _loading = true;
        try { _items = await ContractorService.GetAllAsync(); }
        catch (Exception ex) { Snackbar.Add($"Ошибка: {ex.Message}", Severity.Error); }
        finally { _loading = false; }
    }

    private async Task OpenCreateDialog()
    {
        var parameters = new DialogParameters<ContractorDialog>
        {
            { x => x.Model, new ContractorDialog.ContractorDialogModel() },
            { x => x.IsEdit, false }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ContractorDialog>("Новый контрагент", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: ContractorDialog.ContractorDialogModel model })
        {
            try
            {
                await ContractorService.CreateAsync(new CreateContractorDto
                {
                    Name = model.Name, Inn = model.Inn,
                    ContractorType = model.ContractorType, ExternalId = model.ExternalId
                });
                Snackbar.Add("Контрагент создан", Severity.Success);
                await Load();
            }
            catch (Exception ex) { Snackbar.Add($"Ошибка: {ex.Message}", Severity.Error); }
        }
    }

    private async Task OpenEditDialog(ContractorDto item)
    {
        var model = new ContractorDialog.ContractorDialogModel
        {
            Name = item.Name, Inn = item.Inn,
            ContractorType = item.ContractorType, ExternalId = item.ExternalId
        };
        var parameters = new DialogParameters<ContractorDialog>
        {
            { x => x.Model, model },
            { x => x.IsEdit, true }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ContractorDialog>("Редактирование", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: ContractorDialog.ContractorDialogModel edited })
        {
            try
            {
                await ContractorService.UpdateAsync(item.Id, new UpdateContractorDto
                {
                    Name = edited.Name, Inn = edited.Inn,
                    ContractorType = edited.ContractorType, ExternalId = edited.ExternalId
                });
                Snackbar.Add("Контрагент обновлён", Severity.Success);
                await Load();
            }
            catch (Exception ex) { Snackbar.Add($"Ошибка: {ex.Message}", Severity.Error); }
        }
    }

    private async Task DeleteItem(int id)
    {
        if (!_isAdmin)
        {
            Snackbar.Add("Удаление доступно только администратору", Severity.Warning);
            return;
        }

        try
        {
            await ContractorService.DeleteAsync(id);
            Snackbar.Add("Контрагент удалён", Severity.Success);
            await Load();
        }
        catch (Exception ex) { Snackbar.Add($"Ошибка: {ex.Message}", Severity.Error); }
    }
}
