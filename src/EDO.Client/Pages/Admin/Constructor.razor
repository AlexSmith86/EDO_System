@page "/admin/constructor"
@attribute [Authorize]
@using EDO.Client.Services
@inject IApprovalStageService StageService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudPaper Elevation="0" Class="pa-4 mb-4 rounded-lg" Style="background: linear-gradient(135deg, #1e1e2f 0%, #2a2a40 100%); border: 1px solid #333;">
    <MudText Typo="Typo.h5" Style="font-weight: 700;">Технологический конструктор</MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary">
        Настройка цепочки согласования документов
    </MudText>
</MudPaper>

<MudButton Variant="Variant.Filled" Color="Color.Warning" StartIcon="@Icons.Material.Filled.Add"
           OnClick="@OpenCreateDialog" Class="mb-4" Style="text-transform: none;">
    Добавить этап
</MudButton>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Warning" />
}
else if (_stages.Count == 0)
{
    <MudAlert Severity="Severity.Info">
        Цепочка согласования пуста. Добавьте первый этап.
    </MudAlert>
}
else
{
    <MudTimeline TimelinePosition="TimelinePosition.Start">
        @foreach (var stage in _stages)
        {
            <MudTimelineItem Color="Color.Warning" Variant="Variant.Filled" Size="Size.Medium">
                <ItemDot>
                    <MudText Typo="Typo.body2" Style="font-weight: 700;">@stage.OrderSequence</MudText>
                </ItemDot>
                <ItemContent>
                    <MudCard Elevation="2" Class="pa-3">
                        <div class="d-flex justify-space-between align-center">
                            <div>
                                <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">
                                    @stage.Name
                                </MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    Согласует: <MudChip T="string" Size="Size.Small"
                                                        Color="Color.Primary">@stage.RoleName</MudChip>
                                </MudText>
                            </div>
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                           OnClick="@(() => OpenEditDialog(stage))" />
                        </div>
                    </MudCard>
                </ItemContent>
            </MudTimelineItem>
        }
    </MudTimeline>
}

@code {
    private List<ApprovalStageDto> _stages = new();
    private bool _loading = true;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        _loading = true;
        try { _stages = await StageService.GetAllAsync(); }
        catch (Exception ex) { Snackbar.Add($"Ошибка: {ex.Message}", Severity.Error); }
        finally { _loading = false; }
    }

    private async Task OpenCreateDialog()
    {
        var nextOrder = _stages.Count > 0 ? _stages.Max(s => s.OrderSequence) + 1 : 1;

        var parameters = new DialogParameters<StageDialog>
        {
            { x => x.Model, new StageDialog.StageDialogModel { OrderSequence = nextOrder } },
            { x => x.IsEdit, false }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<StageDialog>("Новый этап", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: StageDialog.StageDialogModel model })
        {
            try
            {
                await StageService.CreateAsync(new CreateApprovalStageDto
                {
                    Name = model.Name, RoleId = model.RoleId, OrderSequence = model.OrderSequence
                });
                Snackbar.Add("Этап создан", Severity.Success);
                await Load();
            }
            catch (Exception ex) { Snackbar.Add($"Ошибка: {ex.Message}", Severity.Error); }
        }
    }

    private async Task OpenEditDialog(ApprovalStageDto stage)
    {
        var model = new StageDialog.StageDialogModel
        {
            Name = stage.Name, RoleId = stage.RoleId, OrderSequence = stage.OrderSequence
        };
        var parameters = new DialogParameters<StageDialog>
        {
            { x => x.Model, model },
            { x => x.IsEdit, true }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<StageDialog>("Редактирование", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: StageDialog.StageDialogModel edited })
        {
            try
            {
                await StageService.UpdateAsync(stage.Id, new UpdateApprovalStageDto
                {
                    Name = edited.Name, RoleId = edited.RoleId, OrderSequence = edited.OrderSequence
                });
                Snackbar.Add("Этап обновлён", Severity.Success);
                await Load();
            }
            catch (Exception ex) { Snackbar.Add($"Ошибка: {ex.Message}", Severity.Error); }
        }
    }
}
