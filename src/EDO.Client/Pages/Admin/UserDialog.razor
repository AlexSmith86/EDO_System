@using EDO.Client.Services
@inject IRoleService RoleService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@(IsEdit ? "Редактирование пользователя" : "Новый пользователь")</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="Model.LastName" Label="Фамилия" Variant="Variant.Outlined"
                      Required="true" Class="mb-3" />
        <MudTextField @bind-Value="Model.FirstName" Label="Имя" Variant="Variant.Outlined"
                      Required="true" Class="mb-3" />
        <MudTextField @bind-Value="Model.MiddleName" Label="Отчество" Variant="Variant.Outlined"
                      Class="mb-3" />
        <MudTextField @bind-Value="Model.Position" Label="Должность" Variant="Variant.Outlined"
                      Required="true" Class="mb-3" />
        <MudTextField @bind-Value="Model.Email" Label="Email" Variant="Variant.Outlined"
                      InputType="InputType.Email" Required="true" Class="mb-3" />
        <MudTextField @bind-Value="Model.Password" Label="@(IsEdit ? "Новый пароль (оставьте пустым)" : "Пароль")"
                      Variant="Variant.Outlined" InputType="InputType.Password"
                      Required="@(!IsEdit)" Class="mb-3" />
        <MudSelect @bind-Value="Model.RoleId" Label="Роль" Variant="Variant.Outlined"
                   Required="true" Class="mb-3">
            @foreach (var role in _roles)
            {
                <MudSelectItem Value="@role.Id">@role.Name</MudSelectItem>
            }
        </MudSelect>
        <MudTextField @bind-Value="Model.TelegramId" Label="Telegram ID" Variant="Variant.Outlined"
                      Class="mb-3" />
        @if (IsEdit)
        {
            <MudSwitch @bind-Value="Model.IsActive" Label="Активен" Color="Color.Success" />
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Отмена</MudButton>
        <MudButton OnClick="Submit" Variant="Variant.Filled" Color="Color.Warning"
                   Style="text-transform: none;">
            @(IsEdit ? "Сохранить" : "Создать")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public UserDialogModel Model { get; set; } = new();

    [Parameter]
    public bool IsEdit { get; set; }

    private List<RoleDto> _roles = new();

    protected override async Task OnInitializedAsync()
    {
        _roles = await RoleService.GetAllAsync();
    }

    private void Cancel() => MudDialog.Cancel();

    private void Submit() => MudDialog.Close(DialogResult.Ok(Model));

    public class UserDialogModel
    {
        public string LastName { get; set; } = string.Empty;
        public string FirstName { get; set; } = string.Empty;
        public string? MiddleName { get; set; }
        public string Position { get; set; } = string.Empty;
        public int RoleId { get; set; }
        public string? TelegramId { get; set; }
        public string Email { get; set; } = string.Empty;
        public string? Password { get; set; }
        public bool IsActive { get; set; } = true;
    }
}
