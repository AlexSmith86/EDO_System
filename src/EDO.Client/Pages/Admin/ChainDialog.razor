@using EDO.Client.Services
@inject IWorkflowChainService ChainService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@(IsEdit ? "Редактирование цепочки" : "Новая цепочка согласования")</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_name" Label="Название цепочки" Variant="Variant.Outlined"
                      Required="true" Class="mb-3" Placeholder="напр. Заявка на IT" />

        @if (IsEdit)
        {
            <MudSwitch @bind-Value="_isActive" Label="Активна" Color="Color.Success" Class="mb-3" />
        }

        <MudText Typo="Typo.subtitle1" Class="mb-2" Style="font-weight: 600;">Шаги согласования</MudText>

        @foreach (var step in _steps)
        {
            var idx = _steps.IndexOf(step);
            <MudCard Elevation="0" Class="pa-3 mb-2" Style="border: 1px solid #444;">
                <MudGrid>
                    <MudItem xs="1" Class="d-flex align-center justify-center">
                        <MudText Typo="Typo.h6" Color="Color.Warning" Style="font-weight: 700;">@step.Order</MudText>
                    </MudItem>
                    <MudItem xs="2">
                        <MudNumericField T="int" Value="step.Order" Label="№ этапа"
                                         Variant="Variant.Outlined" Margin="Margin.Dense"
                                         Min="0" Immediate="true"
                                         ValueChanged="@(v => OnOrderChanged(step, v))" />
                    </MudItem>
                    <MudItem xs="3">
                        <MudTextField @bind-Value="step.StepName" Label="Название шага"
                                      Variant="Variant.Outlined" Margin="Margin.Dense"
                                      Placeholder="напр. Проверка ПТО" />
                    </MudItem>
                    <MudItem xs="4">
                        <MudAutocomplete T="string" @bind-Value="step.TargetPosition"
                                         Label="Должность" Variant="Variant.Outlined"
                                         Dense="true" Margin="Margin.Dense"
                                         SearchFunc="@SearchPositions"
                                         CoerceValue="false" />
                    </MudItem>
                    <MudItem xs="2" Class="d-flex align-center gap-1">
                        <MudIconButton Icon="@Icons.Material.Filled.ArrowUpward" Size="Size.Small"
                                       Disabled="@(idx == 0)"
                                       OnClick="@(() => MoveStep(idx, -1))" />
                        <MudIconButton Icon="@Icons.Material.Filled.ArrowDownward" Size="Size.Small"
                                       Disabled="@(idx == _steps.Count - 1)"
                                       OnClick="@(() => MoveStep(idx, 1))" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                       Color="Color.Error"
                                       OnClick="@(() => RemoveStep(step))" />
                    </MudItem>
                </MudGrid>
            </MudCard>
        }

        <MudButton Variant="Variant.Outlined" Color="Color.Warning"
                   StartIcon="@Icons.Material.Filled.AddCircleOutline"
                   OnClick="@AddStep" Class="mt-2" Style="text-transform: none;">
            Добавить шаг
        </MudButton>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Отмена</MudButton>
        <MudButton OnClick="Submit" Variant="Variant.Filled" Color="Color.Warning"
                   Style="text-transform: none;">
            @(IsEdit ? "Сохранить" : "Создать")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public bool IsEdit { get; set; }
    [Parameter] public WorkflowChainDto? ExistingChain { get; set; }

    private string _name = string.Empty;
    private bool _isActive = true;
    private List<StepRow> _steps = new();
    private List<string> _positions = new();
    private const string AnyPosition = "Любая должность";

    protected override async Task OnInitializedAsync()
    {
        _positions = await ChainService.GetPositionsAsync();
        if (!_positions.Any(p => string.Equals(p, AnyPosition, StringComparison.OrdinalIgnoreCase)))
            _positions.Insert(0, AnyPosition);

        if (IsEdit && ExistingChain is not null)
        {
            _name = ExistingChain.Name;
            _isActive = ExistingChain.IsActive;
            _steps = ExistingChain.Steps
                .OrderBy(s => s.Order)
                .Select(s => new StepRow
                {
                    StepName = s.StepName,
                    TargetPosition = s.TargetPosition,
                    Order = s.Order
                })
                .ToList();
        }
    }

    private void AddStep()
    {
        var nextOrder = _steps.Count > 0 ? _steps.Max(s => s.Order) + 1 : 0;
        _steps.Add(new StepRow { Order = nextOrder });
    }

    private void RemoveStep(StepRow step)
    {
        _steps.Remove(step);
        NormalizeOrderValues();
    }

    private void MoveStep(int index, int direction)
    {
        var newIndex = index + direction;
        if (newIndex < 0 || newIndex >= _steps.Count) return;

        (_steps[index], _steps[newIndex]) = (_steps[newIndex], _steps[index]);
        // Keep custom order numbers, only change visual position.
        _steps = _steps.OrderBy(s => s.Order).ToList();
    }

    private void OnOrderChanged(StepRow step, int? value)
    {
        step.Order = Math.Max(0, value ?? 0);
        NormalizeOrderValues();
    }

    private void NormalizeOrderValues()
    {
        var used = new HashSet<int>();
        foreach (var s in _steps.OrderBy(s => s.Order))
        {
            var order = Math.Max(0, s.Order);
            while (used.Contains(order))
                order++;
            s.Order = order;
            used.Add(order);
        }

        _steps = _steps.OrderBy(s => s.Order).ToList();
    }

    private Task<IEnumerable<string>> SearchPositions(string value, CancellationToken token)
    {
        var result = string.IsNullOrEmpty(value)
            ? _positions.AsEnumerable()
            : _positions.Where(p => p.Contains(value, StringComparison.OrdinalIgnoreCase));
        return Task.FromResult(result);
    }

    private void Cancel() => MudDialog.Cancel();

    private void Submit()
    {
        if (string.IsNullOrWhiteSpace(_name))
            return;

        if (_steps.Count == 0)
            return;

        NormalizeOrderValues();

        MudDialog.Close(DialogResult.Ok(new ChainDialogResult
        {
            Name = _name,
            IsActive = _isActive,
            Steps = _steps
        }));
    }

    public class StepRow
    {
        public string StepName { get; set; } = string.Empty;
        public string TargetPosition { get; set; } = string.Empty;
        public int Order { get; set; }
    }

    public class ChainDialogResult
    {
        public string Name { get; set; } = string.Empty;
        public bool IsActive { get; set; } = true;
        public List<StepRow> Steps { get; set; } = new();
    }
}
