@using EDO.Client.Services
@inject IRoleService RoleService
@inject IWorkflowChainService ChainService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@(IsEdit ? "Редактирование этапа" : "Новый этап согласования")</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="Model.Name" Label="Название этапа" Variant="Variant.Outlined"
                      Required="true" Class="mb-3" />
        <MudSelect T="int?" @bind-Value="Model.RoleId" Label="Роль (кто согласует)" Variant="Variant.Outlined"
                   Class="mb-3" Clearable="true">
            @foreach (var role in _roles)
            {
                <MudSelectItem T="int?" Value="@role.Id">@role.Name</MudSelectItem>
            }
        </MudSelect>
        <MudAutocomplete T="string" @bind-Value="Model.RequiredPosition"
                         Label="Должность (кто согласует)" Variant="Variant.Outlined"
                         SearchFunc="@SearchPositions" CoerceValue="true" Clearable="true"
                         Class="mb-3" />
        <MudNumericField @bind-Value="Model.OrderSequence" Label="Порядковый номер" Variant="Variant.Outlined"
                         Min="1" Required="true" Class="mb-3" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Отмена</MudButton>
        <MudButton OnClick="Submit" Variant="Variant.Filled" Color="Color.Warning"
                   Style="text-transform: none;">
            @(IsEdit ? "Сохранить" : "Создать")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public StageDialogModel Model { get; set; } = new();
    [Parameter] public bool IsEdit { get; set; }

    private List<RoleDto> _roles = new();
    private List<string> _positions = new();

    protected override async Task OnInitializedAsync()
    {
        _roles = await RoleService.GetAllAsync();
        _positions = await ChainService.GetPositionsAsync();
    }

    private Task<IEnumerable<string>> SearchPositions(string value, CancellationToken token)
    {
        var result = string.IsNullOrEmpty(value)
            ? _positions.AsEnumerable()
            : _positions.Where(p => p.Contains(value, StringComparison.OrdinalIgnoreCase));
        return Task.FromResult(result);
    }

    private void Cancel() => MudDialog.Cancel();
    private void Submit() => MudDialog.Close(DialogResult.Ok(Model));

    public class StageDialogModel
    {
        public string Name { get; set; } = string.Empty;
        public int? RoleId { get; set; }
        public string? RequiredPosition { get; set; }
        public int OrderSequence { get; set; } = 1;
    }
}
