@inject AuthenticationStateProvider AuthStateProvider

<MudNavMenu>
    <MudNavLink Href="" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">
        Реестр
    </MudNavLink>
    <MudNavGroup Title="Документы" Icon="@Icons.Material.Filled.Description"
                 Expanded="true">
        <MudNavLink Href="/documents/tmcrequests" Icon="@Icons.Material.Filled.RequestPage">
            Оформление заявки
        </MudNavLink>
        <MudNavLink Href="/documents/approvals" Icon="@Icons.Material.Filled.HowToVote">
            На согласование
        </MudNavLink>
        <MudNavLink Href="/documents/approved" Icon="@Icons.Material.Filled.CheckCircle">
            Согласованные заявки
        </MudNavLink>
    </MudNavGroup>
    <MudNavGroup Title="Справочники" Icon="@Icons.Material.Filled.MenuBook"
                 Expanded="false">
        <MudNavLink Href="/dictionaries/tmcs" Icon="@Icons.Material.Filled.Inventory">
            ТМЦ
        </MudNavLink>
        <MudNavLink Href="/dictionaries/contractors" Icon="@Icons.Material.Filled.Business">
            Контрагенты
        </MudNavLink>
        <MudNavLink Href="/dictionaries/templates" Icon="@Icons.Material.Filled.Description">
            Шаблоны документов
        </MudNavLink>
    </MudNavGroup>
    <MudNavGroup Title="Администрирование" Icon="@Icons.Material.Filled.AdminPanelSettings"
                 Expanded="false">
        <MudNavLink Href="/admin/constructor" Icon="@Icons.Material.Filled.AccountTree">
            Конструктор процессов
        </MudNavLink>
        @if (_isAdmin)
        {
            <MudNavLink Href="/admin/users" Icon="@Icons.Material.Filled.People">
                Пользователи
            </MudNavLink>
        }
    </MudNavGroup>
</MudNavMenu>

@code {
    private bool _isAdmin;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _isAdmin = authState.User.IsInRole("Администратор");
    }
}
