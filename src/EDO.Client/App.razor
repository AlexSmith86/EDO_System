@using Microsoft.AspNetCore.Components.Web

<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(App).Assembly">
        <Found Context="routeData">
            <ErrorBoundary @ref="_errorBoundary">
                <ChildContent>
                    <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
                        <NotAuthorized>
                            <RedirectToLogin />
                        </NotAuthorized>
                    </AuthorizeRouteView>
                    <FocusOnNavigate RouteData="@routeData" Selector="h1" />
                </ChildContent>
                <ErrorContent Context="ex">
                    <div style="padding: 24px; max-width: 640px; margin: 40px auto; font-family: system-ui, sans-serif;">
                        <p style="font-weight: 600; margin-bottom: 8px;">Ошибка при отображении страницы</p>
                        <pre style="white-space: pre-wrap; background: #f5f5f5; padding: 12px; border-radius: 8px; font-size: 13px;">@ex.Message</pre>
                        <button type="button" style="margin-top: 16px; padding: 8px 16px; cursor: pointer;"
                                @onclick="RecoverBoundary">
                            Повторить
                        </button>
                    </div>
                </ErrorContent>
            </ErrorBoundary>
        </Found>
        <NotFound>
            <PageTitle>Не найдено</PageTitle>
            <LayoutView Layout="@typeof(MainLayout)">
                <MudText Typo="Typo.h5">Страница не найдена</MudText>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>

@code {
    private ErrorBoundary? _errorBoundary;

    private void RecoverBoundary() => _errorBoundary?.Recover();
}
